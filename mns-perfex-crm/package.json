{
  "name": "mns-appdriver",
  "version": "2.0.0",
  "description": "MNS aplicação que cria arquivos desktop para Perfex CRM",
  "main": "main.js",
  "email": "contato@meunegociosocial.com",
  "url": "https://mns.marketing",
  "license": "MIT",
  "author": "Lucas Vasconcelos",
  "homepage": "https://mns.marketing",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "nativefier": "^50.1.1",
    "open": "^9.1.0"
  },
  "devDependencies": {
    "electron": "^25.3.1",
    "electron-builder": "^24.6.3",
    "electron-packager": "^17.1.1"
  },
  "build": {
    "appId": "com.example.yourapp",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "asarUnpack": ["node_modules/electron"]
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    }
  }
}